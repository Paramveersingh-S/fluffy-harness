{
    "rules": [
        {
            "tool": "*",
            "action": "allow",
            "log": true,
            "redact": [
                "(?i)api_?key",
                "(?i)password",
                "(?i)token",
                "(?i)secret",
                "(?i)bearer\\s+[A-Za-z0-9_\\-\\.]+",
                "sk-[A-Za-z0-9_]+"
            ]
        }
    ]
}
